# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Genomic Intelligence System"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gis_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=genomic_db
# DATABASE_URL is auto-constructed by docker-compose; override here if needed

# ── Redis / Celery ────────────────────────────────────────────────────────────
# REDIS_URL is auto-constructed by docker-compose; override here if needed

# ── Auth / JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REQUIRE_EMAIL_VERIFICATION=true
# ALLOWED_EMAIL_DOMAINS=denr.gov.ph,region8.denr.gov.ph

# ── File Upload ───────────────────────────────────────────────────────────────
TMP_UPLOAD_DIR=/tmp/gis_uploads
MAX_UPLOAD_SIZE_MB=500
